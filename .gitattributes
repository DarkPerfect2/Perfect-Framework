# Auto detect text files and normalize line endings to LF
* text=auto

# Force LF for these files
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.md text eol=lf
*.npmrc text eol=lf
*.editorconfig text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.zip binary
